# MongoDB connection string (include database name)
DATABASE_URL=mongodb://127.0.0.1:27017/bookhive

# Better Auth — use a long random string in production (e.g. openssl rand -base64 32)
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-min-32-chars

# Public URL of this app (no trailing slash), e.g. http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Same origin as BETTER_AUTH_URL — exposed to the browser for the auth client
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional until configured — leave empty to hide “Continue with Google”)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
